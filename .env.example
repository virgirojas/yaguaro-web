MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/yaguaro?retryWrites=true&w=majority
ADMIN_PASSWORD=cambiar-esta-contraseña

# Vercel Blob (producción). Al conectar el store al proyecto, Vercel agrega BLOB_STORE_ID (OIDC).
# En local: vercel env pull  —  o dejá vacío para guardar en public/uploads/
# BLOB_STORE_ID=
# BLOB_READ_WRITE_TOKEN=   # solo si usás token legacy en lugar de OIDC
